# ─── Trucks Tracking System — Environment Variables ────────────────────────────
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it is already in .gitignore.
#
# For GitHub Actions, add each variable as a Repository Secret in:
#   Settings → Secrets and variables → Actions → New repository secret

# The deployed Apps Script Web App URL
# Get this from: Extensions → Apps Script → Deploy → Manage deployments → Copy "Web app" URL
VITE_APPS_SCRIPT_URL=
